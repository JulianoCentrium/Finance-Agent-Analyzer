# =============================================================================
# Co-Finance — Variáveis de ambiente (Docker Swarm)
# Copie para `deploy/.env` e preencha. NUNCA commite o arquivo real.
# =============================================================================

# ---- Tag das imagens -------------------------------------------------------
# Use uma tag por release (ex.: 2026.04.22, v1.0.0). NÃO use "latest" em produção.
IMAGE_TAG=1.0.0

# Registry para onde as imagens serão publicadas (sem barra final).
# Exemplos: ghcr.io/seu-usuario, registry.suaempresa.com:5000, docker.io/seuusuario
REGISTRY=ghcr.io/seu-usuario

# ---- PostgreSQL (banco interno do stack) ------------------------------------
# Se você usar um Postgres GERENCIADO externo, ignore POSTGRES_* e ajuste
# DATABASE_URL para apontar para ele (ex.: postgres://user:pass@host:5432/db).
POSTGRES_DB=cofinance
POSTGRES_USER=cofinance
# Substitua! Use `openssl rand -base64 32` para gerar.
POSTGRES_PASSWORD=troque-esta-senha-agora

# String de conexão usada pelo api-server e pelo migrator.
# Por padrão aponta para o serviço `postgres` da stack.
DATABASE_URL=postgres://cofinance:troque-esta-senha-agora@postgres:5432/cofinance

# ---- Clerk (autenticação) --------------------------------------------------
# Painel: https://dashboard.clerk.com → API keys
# A SECRET KEY fica APENAS no backend.
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A PUBLISHABLE KEY é embutida no bundle do frontend NA HORA DO BUILD
# (passada via --build-arg). É pública por natureza.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Caminho do proxy do Clerk Frontend API. Mantenha o default a menos que
# você tenha alterado CLERK_PROXY_PATH no código (artifacts/api-server/src/middlewares/clerkProxyMiddleware.ts).
VITE_CLERK_PROXY_URL=/api/__clerk

# ---- CORS ------------------------------------------------------------------
# Lista separada por vírgula com a origem PÚBLICA do frontend (esquema + domínio).
# Em produção sirva o frontend e o backend pelo MESMO domínio (recomendado);
# nesse caso o CORS quase nunca é acionado, mas mantenha a lista correta.
ALLOWED_ORIGINS=https://cofinance.suaempresa.com

# ---- API server ------------------------------------------------------------
LOG_LEVEL=info
NODE_ENV=production
# Porta interna do api-server dentro do container. Não precisa expor para fora.
PORT=8080

# ---- Web (nginx) -----------------------------------------------------------
# Porta do host onde o nginx vai escutar (proxy reverso público).
# Em produção real, deixe um proxy/Traefik na frente fazendo TLS na 443
# e mantenha esta porta interna.
WEB_PUBLIC_PORT=8080
