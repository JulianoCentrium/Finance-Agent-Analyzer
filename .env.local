# =============================================================================
# Co-Finance — Variáveis de ambiente (Teste Local)
# Sistema de autenticação local (sem Clerk)
# =============================================================================

# ---- PostgreSQL (banco interno) -----------------------------------------------
POSTGRES_DB=cofinance
POSTGRES_USER=cofinance
POSTGRES_PASSWORD=cofinance123

# String de conexão para backend
DATABASE_URL=postgres://cofinance:cofinance123@postgres:5432/cofinance

# ---- JWT Authentication (Local) -----------------------------------------------
# Key para assinar JWTs - mude em produção!
JWT_SECRET=dev-local-secret-key-change-in-production

# ---- CORS ------------------------------------------------------------------
# Local apenas
ALLOWED_ORIGINS=http://localhost:8190

# ---- API Server Configuration -----------------------------------------------
LOG_LEVEL=debug
NODE_ENV=development
PORT=8080

# ---- Web Server Configuration -----------------------------------------------
WEB_PUBLIC_PORT=8190
