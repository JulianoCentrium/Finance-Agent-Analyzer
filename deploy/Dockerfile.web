# syntax=docker/dockerfile:1.7

# ---- Stage 1: build -----------------------------------------
FROM node:20-bookworm-slim AS builder

RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

ARG VITE_CLERK_PUBLISHABLE_KEY
ARG VITE_CLERK_PROXY_URL=/api/__clerk

ENV VITE_CLERK_PUBLISHABLE_KEY=${VITE_CLERK_PUBLISHABLE_KEY} \
    VITE_CLERK_PROXY_URL=${VITE_CLERK_PROXY_URL} \
    NODE_ENV=production

# Arquivos do monorepo
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Código
COPY artifacts/finagent artifacts/finagent
COPY lib/api-client-react lib/api-client-react
COPY lib/api-zod lib/api-zod
COPY lib/api-spec lib/api-spec
COPY attached_assets attached_assets
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./

# pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Instalar deps
RUN pnpm install

# Build
WORKDIR /workspace/artifacts/finagent

RUN pnpm exec vite build --config vite.config.ts

# ---- Stage 2: nginx -----------------------------------------

FROM nginx:1.27

COPY deploy/nginx/default.conf /etc/nginx/conf.d/default.conf

COPY --from=builder \
  /workspace/artifacts/finagent/dist/public \
  /usr/share/nginx/html

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]