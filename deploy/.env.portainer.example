# Docker Hub repository
DOCKERHUB_REPO=justbrunasso/cofinance

# Image tags published in Docker Hub
API_TAG=api-local
WEB_TAG=web-local
MIGRATOR_TAG=migrator-local

# Public host routed by Traefik
COFINANCE_HOST=cofinance.seu-dominio.com
TRAEFIK_CERTRESOLVER=letsencrypt

# Service replicas
API_REPLICAS=1
WEB_REPLICAS=1

# Application runtime
NODE_ENV=production
LOG_LEVEL=info
ALLOWED_ORIGINS=https://cofinance.seu-dominio.com
JWT_SECRET=troque-por-um-segredo-forte

# Database
POSTGRES_DB=cofinance
POSTGRES_USER=cofinance
POSTGRES_PASSWORD=troque-por-um-segredo-forte
DATABASE_URL=postgres://cofinance:troque-por-um-segredo-forte@postgres:5432/cofinance
